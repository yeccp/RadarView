{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "if": "Bash(git commit*)",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/check-milestones.sh",
            "statusMessage": "检查 milestones checklist..."
          }
        ]
      }
    ]
  }
}
